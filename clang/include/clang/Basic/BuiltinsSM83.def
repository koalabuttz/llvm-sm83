//
// This file defines the SM83-specific builtin function database.
// Users of this file must define the BUILTIN macro to make use of this
// information.
//
//===----------------------------------------------------------------------===//

// The format of this database matches clang/Basic/Builtins.def.

#if defined(BUILTIN) && !defined(TARGET_BUILTIN)
#   define TARGET_BUILTIN(ID, TYPE, ATTRS, FEATURE) BUILTIN(ID, TYPE, ATTRS)
#endif

// __builtin_sm83_bank_of(fn_ptr) -> unsigned char
//
// At compile time, returns the ROM bank number (1..511) of the referenced
// function, parsed from its `__attribute__((section(".romx.bankN")))`.
// Argument must be a direct reference to a function whose section attribute
// places it in `.romx.bankN` — otherwise Clang emits a diagnostic.
//
// Used by `GB_FAR_PTR(fn)` in gb.h to construct a gb_far_ptr_t without
// requiring the user to keep a bank literal in sync with the section
// attribute.
TARGET_BUILTIN(__builtin_sm83_bank_of, "UcvC*", "ncE", "")

#undef BUILTIN
#undef TARGET_BUILTIN
